{
  "name": "day-boundary",
  "version": "2.1.1",
  "description": "JavaScript library for non-midnight operational day boundaries, DST-safe Temporal window resolution, and shift-aware time-zone logic.",
  "type": "module",
  "main": "./lib/day-boundary-v2.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./lib/day-boundary-v2.js"
    },
    "./v2": {
      "types": "./index.d.ts",
      "default": "./lib/day-boundary-v2.js"
    },
    "./shifts": {
      "types": "./shifts.d.ts",
      "default": "./lib/day-boundary-shifts-v2.js"
    }
  },
  "files": [
    "index.d.ts",
    "shifts.d.ts",
    "lib/day-boundary-v2.js",
    "lib/day-boundary-shifts-v2.js",
    "lib/shifts/",
    "README.md",
    "LICENSE",
    "IP-NOTICE.md",
    "CHANGELOG.md",
    "guides/"
  ],
  "scripts": {
    "test": "node test/run-tests.js",
    "typecheck": "tsc -p tsconfig.types.json"
  },
  "keywords": [
    "temporal",
    "timezone",
    "dst",
    "day-boundary",
    "operational-day",
    "business-day",
    "reporting-window",
    "time-window",
    "shift-scheduling",
    "attendance",
    "payroll"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GazaliAhmad/day-boundary.git"
  },
  "bugs": {
    "url": "https://github.com/GazaliAhmad/day-boundary/issues"
  },
  "homepage": "https://github.com/GazaliAhmad/day-boundary#readme",
  "license": "MIT",
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
